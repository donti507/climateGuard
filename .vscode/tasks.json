{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run ClimateGuard API",
      "type": "shell",
      "command": "mvn",
      "args": ["spring-boot:run"],
      "isBackground": false,
      "problemMatcher": ["$java"],
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "Build ClimateGuard API",
      "type": "shell",
      "command": "mvn",
      "args": ["clean", "install"],
      "isBackground": false,
      "problemMatcher": ["$java"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
